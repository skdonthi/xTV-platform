{
  "name": "x-tv-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Configurable LightningJS Smart TV runtime platform for hospitality, IPTV and OTT.",
  "type": "module",
  "scripts": {
    "dev:samsung": "NX_ISOLATE_PLUGINS=false nx serve samsung",
    "dev:lg": "NX_ISOLATE_PLUGINS=false nx serve lg",
    "dev:android": "NX_ISOLATE_PLUGINS=false nx serve android",
    "build:samsung": "NX_ISOLATE_PLUGINS=false nx build samsung",
    "build:lg": "NX_ISOLATE_PLUGINS=false nx build lg",
    "build:android": "NX_ISOLATE_PLUGINS=false nx build android",
    "build": "NX_ISOLATE_PLUGINS=false nx run-many -t build -p samsung,lg,android",
    "build:tizen6:aida": "NX_ISOLATE_PLUGINS=false nx build samsung --customer=AIDA --profile=tizen6",
    "package:samsung": "node tools/packaging/package-tv.mjs --app=samsung",
    "package:lg": "node tools/packaging/package-tv.mjs --app=lg",
    "package:android": "node tools/packaging/package-tv.mjs --app=android",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "dependencies": {
    "@lightningjs/core": "^2.16.0",
    "@lightningjs/sdk": "^5.5.0",
    "@lightningjs/ui-components": "^1.0.0",
    "i18next": "^25.2.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.0",
    "nx": "^21.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
