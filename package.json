{
  "name": "x-tv-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Configurable LightningJS Smart TV runtime platform for hospitality, IPTV and OTT.",
  "type": "module",
  "scripts": {
    "dev:samsung": "nx serve samsung",
    "dev:lg": "nx serve lg",
    "dev:android": "nx serve android",
    "build:samsung": "nx build samsung",
    "build:lg": "nx build lg",
    "build:android": "nx build android",
    "build": "nx run-many -t build -p samsung,lg,android",
    "build:ccl": "nx run-many -t build -p samsung,lg,android --customer=ccl",
    "package:samsung": "node tools/packaging/package-tv.mjs --app=samsung",
    "package:lg": "node tools/packaging/package-tv.mjs --app=lg",
    "package:android": "node tools/packaging/package-tv.mjs --app=android",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "dependencies": {
    "@lightningjs/blits": "^2.6.0",
    "i18next": "^25.2.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.0",
    "nx": "23.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
